generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id              String     @id @default(uuid(7))
  name            String
  email           String     @unique
  password        String?     
  avatar          String?
  role            Role   @default(USER)
  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  gemas           Gem[]

  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@map("users")

}

model Gem {
  id        String   @id @default(uuid(7))
  amount    Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("gems")
}

